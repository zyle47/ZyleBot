# LM Studio OpenAI-compatible API base URL
LMSTUDIO_BASE_URL=http://localhost:1234/v1

# Model identifier as shown by `lms ps` / LM Studio server
LMSTUDIO_MODEL=qwythos-9b-claude-mythos-5-1m

# --- LLM provider ---
# Which backend serves chat: "lmstudio" (local) or "openrouter" (cloud).
# The app rewrites these three lines itself via the 🔑 API key dialog in the UI —
# normally you never edit them by hand. The key stays saved after Disconnect so
# reconnecting is one click.
LLM_PROVIDER=lmstudio
OPENROUTER_API_KEY=
OPENROUTER_MODEL=
# true = only list OpenRouter's zero-cost ":free" models (no payment method
# needed; OpenRouter rate-limits free requests per day). false = list everything.
OPENROUTER_FREE_ONLY=true

# Sampling temperature. Lower = more consistent/repeatable (steadier tool use),
# higher = more varied. 0.3 is a good steady default.
TEMPERATURE=0.3

# Max ReAct tool-calling steps per turn before the loop forces a final answer
AGENT_MAX_STEPS=12

# Timeout (seconds) for a single LM Studio request
AGENT_REQUEST_TIMEOUT_S=120

# Max bytes read_file will read before refusing (returns an error instead)
TOOL_MAX_FILE_READ_BYTES=1000000

# Max results returned by search_files
TOOL_SEARCH_MAX_RESULTS=200

# SQLite database file path
ZYLEBOT_DB_PATH=data/zylebot.db

# Web server bind address
ZYLEBOT_HOST=127.0.0.1
ZYLEBOT_PORT=8000

# The only globally-shared fact ZyleBot knows across all chats. Leave empty for
# none. Each conversation is otherwise a fresh brain with its own memory.
USER_NAME=

# --- Web access ---
# Search backend: "duckduckgo" needs no API key. Reserved for later: brave, tavily.
SEARCH_PROVIDER=duckduckgo
# Max characters of a fetched page returned to the model (protects the context window).
TOOL_MAX_FETCH_CHARS=8000
# Timeout (seconds) for web search / page fetch requests.
WEB_REQUEST_TIMEOUT_S=20
# Reserved for future key-based providers (leave empty unless you switch provider).
BRAVE_API_KEY=
TAVILY_API_KEY=

# --- Action tools (write/exec — every call requires your approval in the UI) ---
# Max seconds a run_command call may run before it is killed.
COMMAND_TIMEOUT_S=30
# Max characters of command stdout/stderr returned to the model.
COMMAND_MAX_OUTPUT_CHARS=10000

# --- Speech-to-text (local, via faster-whisper) ---
# tiny/base/small/medium/large-v3 — bigger = more accurate but slower.
WHISPER_MODEL_SIZE=small
# "cpu" avoids competing with LM Studio for the shared 12GB of VRAM.
WHISPER_DEVICE=cpu
# int8 on CPU; use float16 if you switch WHISPER_DEVICE to cuda.
WHISPER_COMPUTE_TYPE=int8

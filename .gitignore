# Virtual environment
venv/

# Local config (contains machine-specific settings; copy from .env.example)
.env

# SQLite database + WAL sidecars
data/*.db
data/*.db-wal
data/*.db-shm
data/test_data/*
# Python bytecode / caches
__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/

# RL run/checkpoint output and live evolution viewer snapshots. The promoted
# policy in rl/policy/ is deliberately versioned; these transient outputs are not.
rl/runs/
rl/runs_evo/
rl/policy_evo/

# Editor / OS cruft
.vscode/
.idea/
Thumbs.db

# Claude Code workspace settings (kept out of version control) — except
# subagent definitions in .claude/agents/, which ARE versioned
.claude/*
!.claude/agents/
.codex/*
!.codex/agents/
